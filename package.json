{
  "name": "smart-project-explorer",
  "version": "1.0.0",
  "description": "Smart Project Explorer - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win --x64",
    "build-linux": "electron-builder --linux"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "com.smartexplorer.app",
    "productName": "Smart Project Explorer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
        "electron": "^41.7.1",
    "electron-builder": "^24.13.3"
  }
}
